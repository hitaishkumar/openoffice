generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model floor_cells {
  floor_id      String    @db.Uuid
  row_num       Int
  col_num       Int
  floor_cell_id String    @id @default(dbgenerated("(((((floor_id)::text || '_'::text) || row_num) || '_'::text) || col_num)"))
  cell_type     String?
  capacity      Int?      @default(0)
  is_bookable   Boolean?  @default(false)
  metadata      Json?     @default("{}")
  floors        floors    @relation(fields: [floor_id], references: [floor_id], onDelete: Cascade, onUpdate: NoAction)
  pantries      pantries?

  @@unique([floor_id, row_num, col_num])
  @@index([floor_id], map: "idx_floor_cells_floor")
}

model floors {
  floor_id      String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name          String
  building      String?
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  floor_cells   floor_cells[]
  meeting_rooms meeting_rooms[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model meeting_room_bookings {
  booking_id    String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  room_id       String        @db.Uuid
  title         String
  description   String?
  start_time    DateTime      @db.Timestamptz(6)
  end_time      DateTime      @db.Timestamptz(6)
  booked_by     String?
  status        String?       @default("confirmed")
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?     @default(now()) @db.Timestamptz(6)
  meeting_rooms meeting_rooms @relation(fields: [room_id], references: [room_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([room_id], map: "idx_meeting_room_bookings_room")
  @@index([status], map: "idx_meeting_room_bookings_status")
  @@index([start_time, end_time], map: "idx_meeting_room_bookings_time")
}

model meeting_room_facilities {
  facility_id                       String                              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name                              String                              @unique
  created_at                        DateTime?                           @default(now()) @db.Timestamptz(6)
  meeting_room_facility_assignments meeting_room_facility_assignments[]
}

model meeting_room_facility_assignments {
  id                      String                  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  room_id                 String                  @db.Uuid
  facility_id             String                  @db.Uuid
  meeting_room_facilities meeting_room_facilities @relation(fields: [facility_id], references: [facility_id], onDelete: Cascade, onUpdate: NoAction)
  meeting_rooms           meeting_rooms           @relation(fields: [room_id], references: [room_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([room_id, facility_id])
  @@index([facility_id], map: "idx_meeting_room_facility_assignments_facility")
  @@index([room_id], map: "idx_meeting_room_facility_assignments_room")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model meeting_rooms {
  room_id                           String                              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  floor_id                          String                              @db.Uuid
  room_code                         String
  name                              String
  capacity                          Int
  status                            String?                             @default("available")
  created_at                        DateTime?                           @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime?                           @default(now()) @db.Timestamptz(6)
  meeting_room_bookings             meeting_room_bookings[]
  meeting_room_facility_assignments meeting_room_facility_assignments[]
  floors                            floors                              @relation(fields: [floor_id], references: [floor_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([floor_id, room_code])
  @@index([floor_id], map: "idx_meeting_rooms_floor")
  @@index([status], map: "idx_meeting_rooms_status")
}

model pantries {
  pantry_id           String                @id @default(dbgenerated("uuidv7()")) @db.Uuid
  floor_cell_id       String?               @unique
  name                String
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  floor_cells         floor_cells?          @relation(fields: [floor_cell_id], references: [floor_cell_id], onDelete: Cascade, onUpdate: NoAction)
  pantry_purchases    pantry_purchases[]
  pantry_stock        pantry_stock[]
  pantry_transactions pantry_transactions[]
}

model pantry_categories {
  category_id  String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name         String         @unique
  created_by   String
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  pantry_items pantry_items[]
}

model pantry_items {
  item_id               String                  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name                  String
  category_id           String?                 @db.Uuid
  unit                  String
  price_per_unit        Decimal                 @default(0) @db.Decimal
  is_perishable         Boolean?                @default(false)
  shelf_life_days       Int?
  default_min_threshold Decimal?                @db.Decimal
  default_max_capacity  Decimal?                @db.Decimal
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  pantry_categories     pantry_categories?      @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
  pantry_purchase_items pantry_purchase_items[]
  pantry_stock          pantry_stock[]
  pantry_transactions   pantry_transactions[]

  @@unique([name, category_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pantry_purchase_items {
  id               String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  purchase_id      String?           @db.Uuid
  item_id          String?           @db.Uuid
  quantity         Decimal           @db.Decimal
  cost_per_unit    Decimal           @db.Decimal
  pantry_items     pantry_items?     @relation(fields: [item_id], references: [item_id], onDelete: NoAction, onUpdate: NoAction)
  pantry_purchases pantry_purchases? @relation(fields: [purchase_id], references: [purchase_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pantry_purchases {
  purchase_id           String                  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  pantry_id             String?                 @db.Uuid
  supplier_id           String?                 @db.Uuid
  total_cost            Decimal                 @db.Decimal
  purchased_at          DateTime?               @default(now()) @db.Timestamptz(6)
  pantry_purchase_items pantry_purchase_items[]
  pantries              pantries?               @relation(fields: [pantry_id], references: [pantry_id], onDelete: NoAction, onUpdate: NoAction)
  pantry_suppliers      pantry_suppliers?       @relation(fields: [supplier_id], references: [supplier_id], onDelete: NoAction, onUpdate: NoAction)
}

model pantry_stock {
  pantry_id        String       @db.Uuid
  item_id          String       @db.Uuid
  current_quantity Decimal      @default(0) @db.Decimal
  max_capacity     Decimal?     @db.Decimal
  min_threshold    Decimal?     @db.Decimal
  updated_at       DateTime?    @default(now()) @db.Timestamptz(6)
  pantry_items     pantry_items @relation(fields: [item_id], references: [item_id], onDelete: Cascade, onUpdate: NoAction)
  pantries         pantries     @relation(fields: [pantry_id], references: [pantry_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([pantry_id, item_id])
  @@index([pantry_id, current_quantity], map: "idx_stock_low")
}

model pantry_suppliers {
  supplier_id      String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name             String             @unique
  contact          String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  pantry_purchases pantry_purchases[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pantry_transactions {
  transaction_id   String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  pantry_id        String       @db.Uuid
  item_id          String       @db.Uuid
  quantity         Decimal      @db.Decimal
  unit             String
  transaction_type String
  performed_by     String?      @db.Uuid
  notes            String?
  created_at       DateTime?    @default(now()) @db.Timestamptz(6)
  pantry_items     pantry_items @relation(fields: [item_id], references: [item_id], onDelete: NoAction, onUpdate: NoAction)
  pantries         pantries     @relation(fields: [pantry_id], references: [pantry_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_transactions_created_at")
  @@index([pantry_id, item_id], map: "idx_transactions_pantry_item")
}

model suppliers {
  supplier_id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  supplier_name           String
  display_name            String?
  supplier_code           String?   @unique
  contact_person_name     String?
  contact_email           String?
  contact_phone           String?
  contact_alternate_phone String?
  address_line1           String?
  address_line2           String?
  city                    String?
  state                   String?
  country                 String?   @default("India")
  postal_code             String?
  gst_number              String?
  pan_number              String?
  business_type           String?
  registration_number     String?
  is_active               Boolean?  @default(true)
  is_preferred            Boolean?  @default(false)
  lead_time_days          Int?
  supplier_notes          String?
  tags                    String[]
  bank_name               String?
  account_number          String?
  ifsc                    String?
  upi_id                  String?
  created_at              DateTime? @default(now()) @db.Timestamptz(6)
  created_by              String?
  updated_at              DateTime? @default(now()) @db.Timestamptz(6)
  updated_by              String?
}
